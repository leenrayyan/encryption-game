{
  "name": "signal-lock",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "client",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
