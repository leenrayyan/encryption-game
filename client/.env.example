# Copy these into Netlify's environment variables (Site settings → Environment).
# Values come from your Firebase project settings → "Web app" config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# For local development against the Firebase emulator instead, set this to 1
# (in client/.env.local) and the above can be left blank:
# VITE_USE_EMULATOR=1
